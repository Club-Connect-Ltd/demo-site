---
// This component is the overlay container for the exploded view.
// All interactivity is in the client-side script.
---

<div class="exploded-overlay" id="explodedOverlay" aria-hidden="true" role="dialog" aria-label="Screen annotation view">
  <div class="exploded-overlay__backdrop" id="explodedBackdrop"></div>
  <button class="exploded-overlay__close" id="explodedClose" aria-label="Close annotation view">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <div class="exploded-overlay__content">
    <div class="exploded-overlay__phone-container">
      <div class="exploded-overlay__phone">
        <img src="" alt="" id="explodedImage" />
        <div class="exploded-overlay__callouts" id="explodedCallouts"></div>
      </div>
    </div>

    <div class="exploded-overlay__sidebar" id="explodedSidebar">
      <h3 class="exploded-overlay__title" id="explodedTitle"></h3>
      <p class="exploded-overlay__description" id="explodedDescription"></p>
      <div class="exploded-overlay__details" id="explodedDetails"></div>
    </div>
  </div>

  <div class="exploded-overlay__nav">
    <button class="exploded-overlay__nav-btn" id="explodedPrev" aria-label="Previous screen">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    <span class="exploded-overlay__nav-counter" id="explodedCounter"></span>
    <button class="exploded-overlay__nav-btn" id="explodedNext" aria-label="Next screen">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</div>

<style>
  .exploded-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .exploded-overlay.is-active {
    opacity: 1;
    pointer-events: all;
  }

  .exploded-overlay__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }

  .exploded-overlay__close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 10;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: var(--cc-text-primary);
    transition: background 0.3s ease;
  }

  .exploded-overlay__close:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .exploded-overlay__content {
    position: relative;
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 3rem;
    max-width: 1200px;
    width: 100%;
    padding: 2rem;
  }

  .exploded-overlay.is-landscape .exploded-overlay__content {
    flex-direction: column;
    gap: 1.5rem;
  }

  .exploded-overlay.is-landscape .exploded-overlay__phone {
    width: min(700px, 90vw);
    border-radius: 12px;
  }

  .exploded-overlay.is-landscape .exploded-overlay__sidebar {
    max-width: 700px;
    text-align: center;
  }

  .exploded-overlay__phone-container {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .exploded-overlay__phone {
    position: relative;
    width: 300px;
    border-radius: 44px;
    border: 4px solid #2a2a2a;
    overflow: hidden;
    background: #000;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06),
      0 25px 80px rgba(0, 0, 0, 0.7);
    transform: scale(0.85);
    transition: transform 0.5s var(--ease-out-expo);
  }

  .exploded-overlay.is-active .exploded-overlay__phone {
    transform: scale(1);
  }

  .exploded-overlay__phone img {
    width: 100%;
    height: auto;
    display: block;
  }

  .exploded-overlay__callouts {
    position: absolute;
    inset: 0;
  }

  .exploded-overlay__sidebar {
    flex: 1;
    max-width: 380px;
    transform: translateX(20px);
    opacity: 0;
    transition: transform 0.5s var(--ease-out-expo) 0.2s, opacity 0.5s ease 0.2s;
  }

  .exploded-overlay.is-active .exploded-overlay__sidebar {
    transform: none;
    opacity: 1;
  }

  .exploded-overlay__title {
    font-family: 'Oxanium', sans-serif;
    font-weight: 700;
    font-size: 1.6rem;
    color: var(--cc-text-primary);
    margin-bottom: 0.75rem;
  }

  .exploded-overlay__description {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    color: var(--cc-text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .exploded-overlay__details {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .exploded-overlay__nav {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
  }

  .exploded-overlay__nav-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: var(--cc-text-secondary);
    transition: color 0.3s ease, background 0.3s ease;
  }

  .exploded-overlay__nav-btn:hover {
    color: var(--cc-text-primary);
    background: rgba(255, 255, 255, 0.1);
  }

  .exploded-overlay__nav-counter {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 0.8rem;
    color: var(--cc-text-secondary);
    min-width: 3rem;
    text-align: center;
  }

  @media (max-width: 767px) {
    .exploded-overlay__content {
      flex-direction: column;
      gap: 1.5rem;
      padding: 4rem 1rem 5rem;
      overflow-y: auto;
      max-height: 100vh;
    }

    .exploded-overlay__phone {
      width: 240px;
    }

    .exploded-overlay__sidebar {
      max-width: 100%;
      text-align: center;
    }
  }
</style>
