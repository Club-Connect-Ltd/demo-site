---
interface Props {
  value: string;
  label: string;
  suffix?: string;
  isNumber?: boolean;
  delay?: number;
}

const { value, label, suffix = '', isNumber = false, delay = 0 } = Astro.props;
---

<div class="metric-card" data-animate="fade-up" style={`--delay: ${delay}`}>
  <div class="metric-card__value" data-count-target={isNumber ? value : undefined}>
    {value}{suffix}
  </div>
  <div class="metric-card__label">{label}</div>
</div>

<style>
  .metric-card {
    text-align: center;
    padding: 2.5rem 1.5rem;
    border-radius: 16px;
    background: var(--cc-bg-card);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .metric-card:hover {
    transform: translateY(-4px);
    border-color: rgba(195, 255, 77, 0.2);
  }

  .metric-card__value {
    font-family: 'Oxanium', sans-serif;
    font-weight: 800;
    font-size: var(--fs-stat-number);
    color: var(--cc-primary);
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .metric-card__label {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: var(--fs-body);
    color: var(--cc-text-secondary);
  }
</style>
