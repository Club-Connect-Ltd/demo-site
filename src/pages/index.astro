---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import PhoneFrame from '../components/PhoneFrame.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FeatureBadge from '../components/FeatureBadge.astro';
import PainPointCard from '../components/PainPointCard.astro';
import MetricCard from '../components/MetricCard.astro';
import FlowCarousel from '../components/FlowCarousel.astro';
import ExplodedView from '../components/ExplodedView.astro';
import Footer from '../components/Footer.astro';

// -- Screenshots --
import firstRun1 from '../assets/screenshots/first-run/IMG_0968.PNG';
import firstRun2 from '../assets/screenshots/first-run/IMG_0969.PNG';
import firstRun3 from '../assets/screenshots/first-run/IMG_0970.PNG';

import createClub1 from '../assets/screenshots/create-club/IMG_0971.PNG';
import createClub2 from '../assets/screenshots/create-club/IMG_0972.PNG';
import createClub3 from '../assets/screenshots/create-club/IMG_0973.PNG';

import aiEvent1 from '../assets/screenshots/ai-create-event/IMG_0974.PNG';
import aiEvent2 from '../assets/screenshots/ai-create-event/IMG_0975.PNG';

import newEvent1 from '../assets/screenshots/create-new-event/IMG_0976.PNG';
import newEvent2 from '../assets/screenshots/create-new-event/IMG_0977.PNG';
import newEvent3 from '../assets/screenshots/create-new-event/IMG_0978.PNG';
import newEvent4 from '../assets/screenshots/create-new-event/IMG_0979.PNG';
import newEvent5 from '../assets/screenshots/create-new-event/IMG_0980.PNG';

import messages1 from '../assets/screenshots/messages/IMG_0981.PNG';
import messages2 from '../assets/screenshots/messages/IMG_0982.PNG';
import messages3 from '../assets/screenshots/messages/IMG_0983.PNG';

import attendance1 from '../assets/screenshots/attendance/IMG_0984.PNG';
import attendance2 from '../assets/screenshots/attendance/IMG_0985.PNG';

import playerFinder1 from '../assets/screenshots/player-finder/IMG_0989.PNG';
import playerFinder2 from '../assets/screenshots/player-finder/IMG_0990.PNG';
import playerFinder3 from '../assets/screenshots/player-finder/IMG_0991.PNG';

import childAccount1 from '../assets/screenshots/create-child-account/IMG_0992.PNG';
import childAccount2 from '../assets/screenshots/create-child-account/IMG_0993.PNG';
import childAccount3 from '../assets/screenshots/create-child-account/IMG_0994.PNG';
import childAccount4 from '../assets/screenshots/create-child-account/IMG_0995.PNG';
import childAccount5 from '../assets/screenshots/create-child-account/IMG_0996.PNG';

import eventsView1 from '../assets/screenshots/events/IMG_0998.PNG';
import eventsView2 from '../assets/screenshots/events/IMG_0999.PNG';
import eventsView3 from '../assets/screenshots/events/IMG_1001.PNG';

import { Image } from 'astro:assets';
import logoLight from '../assets/logo-light.png';
---

<BaseLayout>
  <Navbar />

  <main>
    <!-- ============================================
         SECTION 1: HERO
         ============================================ -->
    <section class="hero section" id="hero">
      <div class="ambient-orb ambient-orb--primary hero__orb"></div>

      <div class="container hero__content">
        <div class="hero__text" data-animate="fade-up">
          <div class="hero__logo">
            <Image src={logoLight} alt="Club Connect Logo" width={80} format="webp" />
          </div>
          <h1 class="hero__title">
            The Operating System for<br />
            <span class="gradient-text">Community Sports</span>
          </h1>
          <p class="hero__subtitle">
            Club Connect brings together players, coaches, parents, and officials
            in one intelligent platform.
          </p>
        </div>

        <div class="hero__phones">
          <PhoneFrame
            src={firstRun2}
            alt="Find Your Team"
            animateDirection="fade-up"
            delay={1}
            annotationId="IMG_0969"
            class="hero__phone hero__phone--left"
          />
          <PhoneFrame
            src={firstRun1}
            alt="Welcome to Club Connect"
            animateDirection="fade-up"
            delay={0}
            annotationId="IMG_0968"
            class="hero__phone hero__phone--center"
          />
          <PhoneFrame
            src={firstRun3}
            alt="Sign In Options"
            animateDirection="fade-up"
            delay={2}
            annotationId="IMG_0970"
            class="hero__phone hero__phone--right"
          />
        </div>

        <div class="hero__scroll-hint" data-animate="fade-in" style="--delay: 4">
          <span>Scroll to explore</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 2: PROBLEM STATEMENT
         ============================================ -->
    <section class="section section--alt" id="problem">
      <div class="container">
        <SectionHeader
          tag="The Problem"
          title="Community Sports Clubs Deserve Better Tools"
          subtitle="Coaches juggle WhatsApp groups, spreadsheets, and paper sign-up sheets. There has to be a better way."
        />

        <div class="pain-cards">
          <PainPointCard
            icon="💬"
            title="Scattered Communication"
            description="5+ WhatsApp groups per team. Important messages get lost in the noise. Parents miss training updates."
            delay={0}
          />
          <PainPointCard
            icon="📋"
            title="Manual Event Planning"
            description="Fixtures, training, and socials managed via spreadsheets and memory. Double bookings and no-shows are common."
            delay={1}
          />
          <PainPointCard
            icon="🏢"
            title="No Central Hub"
            description="Club admin is fragmented across email, paper forms, and word of mouth. No single source of truth."
            delay={2}
          />
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 3: CLUB SETUP FLOW
         ============================================ -->
    <section class="section" id="club-setup">
      <div class="container">
        <SectionHeader
          tag="Onboarding"
          title="Your Club, Up and Running in Minutes"
          subtitle="A guided wizard takes you from zero to a fully configured club in under 2 minutes."
        />

        <div class="flow-steps">
          <div class="flow-step" data-animate="fade-up" style="--delay: 0">
            <div class="flow-step__number">1</div>
            <PhoneFrame
              src={createClub1}
              alt="Set Club Location"
              annotationId="IMG_0971"
              delay={0}
            />
            <p class="flow-step__label">Set Location</p>
          </div>

          <div class="flow-step__connector" data-animate="fade-in" style="--delay: 1">
            <svg width="60" height="2" viewBox="0 0 60 2">
              <line x1="0" y1="1" x2="60" y2="1" stroke="rgba(195,255,77,0.3)" stroke-width="2" stroke-dasharray="4 4" />
            </svg>
          </div>

          <div class="flow-step" data-animate="fade-up" style="--delay: 1">
            <div class="flow-step__number">2</div>
            <PhoneFrame
              src={createClub2}
              alt="Choose Age Groups"
              annotationId="IMG_0972"
              delay={1}
            />
            <p class="flow-step__label">Choose Age Groups</p>
          </div>

          <div class="flow-step__connector" data-animate="fade-in" style="--delay: 2">
            <svg width="60" height="2" viewBox="0 0 60 2">
              <line x1="0" y1="1" x2="60" y2="1" stroke="rgba(195,255,77,0.3)" stroke-width="2" stroke-dasharray="4 4" />
            </svg>
          </div>

          <div class="flow-step" data-animate="fade-up" style="--delay: 2">
            <div class="flow-step__number flow-step__number--success">✓</div>
            <div class="flow-step__glow">
              <PhoneFrame
                src={createClub3}
                alt="Club Created"
                annotationId="IMG_0973"
                delay={2}
              />
            </div>
            <p class="flow-step__label">You're Live!</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 4: AI EVENT CREATION — THE USP
         ============================================ -->
    <section class="section section--ai" id="ai-events">
      <div class="ambient-orb ambient-orb--strong ai__orb"></div>
      <div class="ambient-orb ambient-orb--primary ai__orb-2"></div>

      <div class="container">
        <div class="ai__header" data-animate="fade-up">
          <FeatureBadge label="AI-Powered" icon="✨" glow={true} />
        </div>

        <SectionHeader
          tag="Key Differentiator"
          title="AI-Powered Event Creation"
          subtitle="Just tell it what you want. The AI handles the rest."
          gradient={true}
        />

        <div class="ai__phones">
          <div class="ai__phone-group" data-animate="fade-right" style="--delay: 0">
            <PhoneFrame
              src={aiEvent1}
              alt="AI Chat — Describe Your Event"
              size="large"
              annotationId="IMG_0974"
              delay={0}
            />
            <p class="ai__phone-caption">Describe in plain English</p>
          </div>

          <div class="ai__arrow" data-animate="fade-in" style="--delay: 1">
            <svg width="80" height="40" viewBox="0 0 80 40">
              <path d="M0 20 L60 20 M50 10 L62 20 L50 30" stroke="var(--cc-primary)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.6">
                <animate attributeName="opacity" values="0.3;1;0.3" dur="2s" repeatCount="indefinite" />
              </path>
            </svg>
          </div>

          <div class="ai__phone-group" data-animate="fade-left" style="--delay: 1">
            <PhoneFrame
              src={aiEvent2}
              alt="AI Creates Structured Event"
              size="large"
              annotationId="IMG_0975"
              delay={1}
            />
            <p class="ai__phone-caption">Event created in seconds</p>
          </div>
        </div>

        <!-- Typing Demo -->
        <div class="typing-demo" id="typingDemo" data-animate="fade-up" style="--delay: 2">
          <div class="typing-demo__window">
            <div class="typing-demo__header">
              <div class="typing-demo__dot typing-demo__dot--red"></div>
              <div class="typing-demo__dot typing-demo__dot--yellow"></div>
              <div class="typing-demo__dot typing-demo__dot--green"></div>
              <span class="typing-demo__title">AI Event Assistant</span>
            </div>
            <div class="typing-demo__body">
              <div class="typing-demo__user" style="visibility: hidden;"></div>
              <div class="typing-demo__ai">
                <span class="typing-demo__avatar">🤖</span>
                <span class="typing-demo__text"></span>
              </div>
              <div class="typing-demo__user-reply" style="visibility: hidden;"></div>
              <div class="typing-demo__result">
                <div class="typing-demo__result-icon">🏃</div>
                <div class="typing-demo__result-content">
                  <strong>Training</strong>
                  <span>Tuesday, Apr 14, 2026 · 6:00 pm</span>
                  <span>Main Training Pitch</span>
                </div>
              </div>
              <div class="typing-demo__cursor">|</div>
            </div>
          </div>
        </div>

        <p class="ai__callout" data-animate="fade-up" style="--delay: 3">
          From words to scheduled events in seconds — no forms, no friction.
        </p>
      </div>
    </section>

    <!-- ============================================
         SECTION 5: EVENT MANAGEMENT
         ============================================ -->
    <section class="section section--alt" id="events">
      <div class="container">
        <SectionHeader
          tag="Event Management"
          title="Every Event Type, One Workflow"
          subtitle="Matches, training sessions, and social events — each with purpose-built forms and smart defaults."
        />

        <div class="events__badges" data-animate="fade-up">
          <FeatureBadge label="Match" variant="primary" />
          <FeatureBadge label="Training" variant="accent" />
          <FeatureBadge label="Social" variant="neutral" />
        </div>

        <FlowCarousel id="events-carousel">
          <PhoneFrame src={newEvent1} alt="Events Dashboard" annotationId="IMG_0976" delay={0} />
          <PhoneFrame src={newEvent2} alt="Training Event Form" annotationId="IMG_0977" delay={1} />
          <PhoneFrame src={newEvent3} alt="Social Event Options" annotationId="IMG_0978" delay={2} />
          <PhoneFrame src={newEvent4} alt="Match Setup" annotationId="IMG_0979" delay={3} />
          <PhoneFrame src={newEvent5} alt="Discard Changes Dialog" annotationId="IMG_0980" delay={4} />
        </FlowCarousel>

        <div class="events__detail-callout" data-animate="fade-up" style="--delay: 3">
          <span class="events__detail-icon">💡</span>
          <span>Thoughtful UX details like unsaved-changes protection show the depth of our product thinking.</span>
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 6: EVENTS VIEW
         ============================================ -->
    <section class="section" id="events-view">
      <div class="container">
        <SectionHeader
          tag="Schedule"
          title="Your Calendar, Always Up to Date"
          subtitle="Upcoming fixtures, training, and socials in one chronological view. Filter by type, manage recurring series."
        />

        <div class="events-view__badges" data-animate="fade-up">
          <FeatureBadge label="Upcoming" variant="primary" />
          <FeatureBadge label="Series" variant="accent" />
          <FeatureBadge label="Filters" variant="neutral" />
        </div>

        <div class="events-view__phones">
          <PhoneFrame
            src={eventsView1}
            alt="Upcoming Events"
            animateDirection="fade-up"
            delay={0}
            annotationId="IMG_0998"
          />
          <PhoneFrame
            src={eventsView2}
            alt="Event Type Filter"
            animateDirection="fade-up"
            delay={1}
            annotationId="IMG_0999"
          />
          <PhoneFrame
            src={eventsView3}
            alt="Event Series"
            animateDirection="fade-up"
            delay={2}
            annotationId="IMG_1001"
          />
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 7: ATTENDANCE
         ============================================ -->
    <section class="section section--alt" id="attendance">
      <div class="container">
        <SectionHeader
          tag="Attendance"
          title="Know Who's Coming, Instantly"
          subtitle="Real-time RSVP tracking with at-a-glance summaries. Players respond in one tap, coaches plan with confidence."
        />

        <div class="attendance__phones">
          <PhoneFrame
            src={attendance1}
            alt="Attendance Overview"
            animateDirection="fade-right"
            delay={0}
            annotationId="IMG_0984"
          />
          <PhoneFrame
            src={attendance2}
            alt="RSVP Response"
            animateDirection="fade-left"
            delay={1}
            annotationId="IMG_0985"
          />
        </div>

        <div class="attendance__summary" data-animate="fade-up" style="--delay: 2">
          <div class="attendance__badge attendance__badge--going">
            <span class="attendance__badge-num">5</span>
            <span class="attendance__badge-label">Going</span>
          </div>
          <div class="attendance__badge attendance__badge--not-going">
            <span class="attendance__badge-num">5</span>
            <span class="attendance__badge-label">Not Going</span>
          </div>
          <div class="attendance__badge attendance__badge--maybe">
            <span class="attendance__badge-num">3</span>
            <span class="attendance__badge-label">Maybe</span>
          </div>
          <div class="attendance__badge attendance__badge--pending">
            <span class="attendance__badge-num">2</span>
            <span class="attendance__badge-label">Pending</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 8: MESSAGING
         ============================================ -->
    <section class="section" id="messaging">
      <div class="container">
        <SectionHeader
          tag="Communication"
          title="Communication, Centralised"
          subtitle="Replace scattered WhatsApp groups with one unified, structured messaging platform."
        />

        <div class="messaging__badges" data-animate="fade-up">
          <FeatureBadge label="Team Channels" variant="primary" />
          <FeatureBadge label="Broadcasts" variant="accent" />
          <FeatureBadge label="Direct Messages" variant="neutral" />
          <FeatureBadge label="Read-Only Admin" variant="neutral" />
        </div>

        <div class="messaging__phones">
          <PhoneFrame
            src={messages1}
            alt="Messages Inbox"
            animateDirection="fade-up"
            delay={0}
            annotationId="IMG_0981"
          />
          <PhoneFrame
            src={messages2}
            alt="Broadcast Channel"
            animateDirection="fade-up"
            delay={1}
            annotationId="IMG_0982"
          />
          <PhoneFrame
            src={messages3}
            alt="Team Group Chat"
            animateDirection="fade-up"
            delay={2}
            annotationId="IMG_0983"
          />
        </div>

        <div class="messaging__stat" data-animate="scale-up" style="--delay: 2">
          <span class="messaging__stat-number">5+</span>
          <span class="messaging__stat-text">WhatsApp groups replaced with 1 unified inbox</span>
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 9: PLAYER FINDER
         ============================================ -->
    <section class="section section--alt" id="player-finder">
      <div class="container">
        <SectionHeader
          tag="Recruitment"
          title="Find Players, Build Squads"
          subtitle="A marketplace connecting players seeking clubs with clubs seeking players. Filter by age, position, skill level, and location."
        />

        <div class="player-finder__badges" data-animate="fade-up">
          <FeatureBadge label="Browse" variant="primary" />
          <FeatureBadge label="Shortlist" variant="accent" />
          <FeatureBadge label="Create Profile" variant="neutral" />
        </div>

        <div class="player-finder__phones">
          <PhoneFrame
            src={playerFinder1}
            alt="Browse Players & Clubs"
            animateDirection="fade-up"
            delay={0}
            annotationId="IMG_0989"
          />
          <PhoneFrame
            src={playerFinder2}
            alt="Shortlist"
            animateDirection="fade-up"
            delay={1}
            annotationId="IMG_0990"
          />
          <PhoneFrame
            src={playerFinder3}
            alt="Create Profile"
            animateDirection="fade-up"
            delay={2}
            annotationId="IMG_0991"
          />
        </div>

        <div class="player-finder__callout" data-animate="fade-up" style="--delay: 2">
          <span class="player-finder__callout-icon">⚽</span>
          <span>Like a transfer market for grassroots football</span>
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 10: CREATE CHILD ACCOUNT
         ============================================ -->
    <section class="section" id="child-accounts">
      <div class="container">
        <SectionHeader
          tag="Safeguarding"
          title="Safe Accounts for Young Players"
          subtitle="Age-appropriate Player-Lite accounts with parental controls, multi-guardian support, and restricted communications."
        />

        <div class="child-accounts__badges" data-animate="fade-up">
          <FeatureBadge label="Player-Lite" variant="primary" />
          <FeatureBadge label="Multi-Guardian" variant="accent" />
          <FeatureBadge label="Age Restrictions" variant="neutral" />
        </div>

        <FlowCarousel id="child-accounts-carousel">
          <PhoneFrame src={childAccount1} alt="Add Your Child" annotationId="IMG_0992" delay={0} />
          <PhoneFrame src={childAccount2} alt="Account Features" annotationId="IMG_0993" delay={1} />
          <PhoneFrame src={childAccount3} alt="Additional Guardians" annotationId="IMG_0994" delay={2} />
          <PhoneFrame src={childAccount4} alt="Confirmation" annotationId="IMG_0995" delay={3} />
          <PhoneFrame src={childAccount5} alt="Account Created" annotationId="IMG_0996" delay={4} />
        </FlowCarousel>

        <div class="child-accounts__callout" data-animate="fade-up" style="--delay: 3">
          <span class="child-accounts__callout-icon">🛡️</span>
          <span>Built with safeguarding at the core — GDPR compliant for under-16s</span>
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 11: METRICS
         ============================================ -->
    <section class="section section--alt" id="metrics">
      <div class="container">
        <SectionHeader
          tag="By the Numbers"
          title="Built for Real Clubs"
        />

        <div class="metrics-grid">
          <MetricCard value="< 2" suffix=" min" label="Club setup time" delay={0} />
          <MetricCard value="9" label="Core user flows" delay={1} isNumber={true} />
          <MetricCard value="AI" label="Powered event creation" delay={2} />
          <MetricCard value="All" label="Ages — Under 6 to Veterans" delay={3} />
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 8: BUILT FOR SCALE
         ============================================ -->
    <section class="section" id="tech">
      <div class="container">
        <SectionHeader
          tag="Technology"
          title="Built for Scale"
          subtitle="Native performance, modern architecture, and accessibility-first design."
        />

        <div class="tech-grid">
          <div class="tech-card" data-animate="fade-up" style="--delay: 0">
            <div class="tech-card__icon">📱</div>
            <h3 class="tech-card__title">Native iOS</h3>
            <p class="tech-card__desc">Built with SwiftUI for buttery-smooth 60fps performance and native feel.</p>
          </div>
          <div class="tech-card" data-animate="fade-up" style="--delay: 1">
            <div class="tech-card__icon">🤖</div>
            <h3 class="tech-card__title">AI Integration</h3>
            <p class="tech-card__desc">Natural language processing turns conversational input into structured data.</p>
          </div>
          <div class="tech-card" data-animate="fade-up" style="--delay: 2">
            <div class="tech-card__icon">⚡</div>
            <h3 class="tech-card__title">Real-time Messaging</h3>
            <p class="tech-card__desc">Instant delivery with push notifications, read receipts, and channel management.</p>
          </div>
          <div class="tech-card" data-animate="fade-up" style="--delay: 3">
            <div class="tech-card__icon">♿</div>
            <h3 class="tech-card__title">Accessibility First</h3>
            <p class="tech-card__desc">WCAG AAA contrast targets, dynamic type support, and VoiceOver optimised.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 9: CALL TO ACTION
         ============================================ -->
    <section class="section section--cta" id="cta">
      <div class="ambient-orb ambient-orb--primary cta__orb"></div>
      <div class="container cta__content">
        <div class="cta__text" data-animate="fade-up">
          <h2 class="cta__title">
            Ready to Transform<br />
            <span class="gradient-text">Community Sports?</span>
          </h2>
          <p class="cta__subtitle">
            Club Connect is seeking investment to expand our platform across the UK and beyond.
          </p>
        </div>

        <div class="cta__buttons" data-animate="fade-up" style="--delay: 1">
          <a href="#" class="cta__btn cta__btn--primary" onclick="event.preventDefault()">Schedule a Demo</a>
          <a href="#" class="cta__btn cta__btn--outline" onclick="event.preventDefault()">Download Pitch Deck</a>
        </div>
      </div>
    </section>
  </main>

  <ExplodedView />
  <Footer />

  <script src="../scripts/animations.ts"></script>
  <script src="../scripts/exploded-view.ts"></script>
  <script src="../scripts/typing-demo.ts"></script>
</BaseLayout>

<style>
  /* ============================================
     HERO
     ============================================ */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 6rem;
    padding-bottom: 2rem;
    text-align: center;
    position: relative;
  }

  .hero__orb {
    width: 700px;
    height: 700px;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  .hero__text {
    max-width: 800px;
  }

  .hero__logo {
    margin-bottom: 1.5rem;
  }

  .hero__logo :global(img) {
    width: 80px;
    height: auto;
    margin: 0 auto;
  }

  .hero__title {
    font-family: 'Oxanium', sans-serif;
    font-weight: 800;
    font-size: var(--fs-hero);
    color: var(--cc-text-primary);
    margin-bottom: 1.25rem;
    line-height: 1.1;
  }

  .hero__subtitle {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: var(--fs-subtitle);
    color: var(--cc-text-secondary);
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.7;
